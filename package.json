{
  "name": "rouge-score-js",
  "version": "0.0.1",
  "description": "TypeScript implementation of ROUGE evaluation metrics for text summarization.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itsdeepeshsingh/rouge-score-js.git"
  },
  "bugs": {
    "url": "https://github.com/itsdeepeshsingh/rouge-score-js/issues"
  },
  "homepage": "https://github.com/itsdeepeshsingh/rouge-score-js#readme",
  "keywords": [
    "rouge",
    "rouge-score",
    "summarization",
    "evaluation",
    "nlp",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "browser": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --sourcemap",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "pack:check": "npm pack --dry-run --cache .npm-cache",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^24.0.10",
    "eslint": "^9.30.1",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.4"
  }
}
